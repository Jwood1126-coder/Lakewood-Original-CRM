# Normalize line endings to LF for all text files
* text=auto eol=lf

# Explicitly LF
*.py text eol=lf
*.html text eol=lf
*.css text eol=lf
*.md text eol=lf
*.ini text eol=lf
*.json text eol=lf
*.txt text eol=lf
*.cfg text eol=lf
*.toml text eol=lf
Procfile text eol=lf

# Binary
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.pdf binary
