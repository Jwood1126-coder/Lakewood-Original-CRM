# ==============================================================
# Handyman CRM — environment variables
# Copy this file to `.env` for local dev, or set in Railway dashboard.
# ==============================================================

# --- Required ---

# Random long string. Generate with:  python -c "import secrets; print(secrets.token_urlsafe(48))"
SECRET_KEY=change-me-to-a-long-random-string

# Where SQLite lives. Local default below; Railway should set to /data/app.db
DATABASE_URL=sqlite:///./data/app.db

# Where uploaded photos go. Local default below; Railway should set to /data/photos
PHOTO_DIR=./data/photos

# Where archived HTML snapshots go (Phase 3+)
ARCHIVE_DIR=./data/archive

# Where local backups are written before upload to B2
BACKUP_DIR=./data/backups

# Initial admin user (created on first run if no User exists).
# After first run, the admin can change their own password in /settings.
ADMIN_EMAIL=Jakewood@lakewoodoriginal.com
ADMIN_PASSWORD=change-me-on-first-login

# Business display info (for invoice/quote headers — Phase 3)
BUSINESS_NAME=Lakewood Original
BUSINESS_ADDRESS=
BUSINESS_PHONE=
BUSINESS_EMAIL=Jakewood@lakewoodoriginal.com

# Default Ohio county for new properties (used until ZIP lookup runs)
DEFAULT_COUNTY=Cuyahoga

# Time zone for rendering
APP_TIMEZONE=America/New_York

# --- Optional / Phase-gated ---

# Anthropic (Phase 5 — assistant). If unset, assistant routes return a friendly stub.
# ANTHROPIC_API_KEY=sk-ant-...
# ANTHROPIC_MODEL=claude-opus-4-7

# SMTP for notifications-to-self (briefings, reminders). Never sent to customers.
# Defaults: Outlook.com personal (smtp-mail.outlook.com:587 + STARTTLS).
# Gmail: set SMTP_HOST=smtp.gmail.com SMTP_PORT=465 SMTP_USE_TLS=0
# Microsoft 365: set SMTP_HOST=smtp.office365.com (admin must allow SMTP AUTH)
# SMTP_HOST=smtp-mail.outlook.com
# SMTP_PORT=587
# SMTP_USE_TLS=1
# SMTP_USER=jake@outlook.com
# SMTP_PASSWORD=xxxxxxxxxxxxxxxx
# NOTIFY_EMAIL=jake@outlook.com, jake@gmail.com   # comma-sep for multiple recipients

# Backblaze B2 (Phase 1 backups). If unset, backups stay local.
# B2_ENDPOINT_URL=https://s3.us-east-005.backblazeb2.com
# B2_KEY_ID=
# B2_APPLICATION_KEY=
# B2_BUCKET=handyman-crm-backups

# Stripe (Phase 6 — payment links).
# STRIPE_SECRET_KEY=sk_live_...
# STRIPE_WEBHOOK_SECRET=whsec_...

# Intake API CORS allow-list (Issue #4). Comma-separated full origins
# (scheme://host[:port]) permitted to POST to /intake/api/request.
# Defaults cover prod + www + localhost. Add staging URLs here as needed.
# INTAKE_CORS_ORIGINS=https://lakewoodoriginal.com,https://www.lakewoodoriginal.com,https://staging.lakewoodoriginal.com,http://localhost:8000

# --- Flask runtime ---
FLASK_APP=wsgi:app
FLASK_DEBUG=1
